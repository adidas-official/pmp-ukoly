<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".categoryActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#ECEFF1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- PODVÁHA -->

            <Button
                android:id="@+id/button2"
                android:layout_width="385dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="#00FFFFFF"
                android:onClick="goToBMI"
                android:text="Zpět"
                android:textColor="@color/blue"
                android:textSize="25dp"
                app:cornerRadius="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/result_blue"
                android:padding="16dp"
                android:text="Podváha\nméně než 18.5\nNižší než zdravá hmotnost."
                android:textColor="@color/white"
                android:textSize="18sp" />

            <!-- NORMÁLNÍ VÁHA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/result_green"
                android:padding="16dp"
                android:text="Normální váha\n18.5 až 24.9\nZdravá hmotnost."
                android:textColor="@color/white"
                android:textSize="18sp" />

            <!-- NADVÁHA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/result_orange"
                android:padding="16dp"
                android:text="Nadváha\n25.0 až 29.9\nVyšší než ideální hmotnost."
                android:textColor="@color/white"
                android:textSize="18sp" />

            <!-- OBEZITA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/result_red"
                android:padding="16dp"
                android:text="Obezita\nvíce než 30.0\nNebezpečně vysoká hmotnost."
                android:textColor="@color/white"
                android:textSize="18sp" />

        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>